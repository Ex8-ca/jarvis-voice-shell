# Copy this file to .env or set these variables in your shell before launching.
# Do not commit real secrets.

# Required only when using Hermes Gateway HTTP mode.
# Use any private local value, then start the gateway and client with the same value.
API_SERVER_KEY=
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
HERMES_BRIDGE_URL=http://127.0.0.1:8642/v1/chat/completions
BRIDGE_MAX_TOKENS=512

# Required only for OpenAI Realtime voice mode.
OPENAI_API_KEY=

# Optional voice/runtime tuning.
JARVIS_TTS_VOICE=en-GB-RyanNeural
JARVIS_TTS_RATE=+10%
JARVIS_STT_ENGINE=whisper
JARVIS_STT_MODEL=tiny
